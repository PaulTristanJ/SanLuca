generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model MenuCategory {
  id        String   @id @default(cuid())
  name      String
  position  Int?     // orden en el menú
  dishes    Dish[]
  createdAt DateTime @default(now())
}

model Dish {
  id          String   @id @default(cuid())
  name        String
  description String?
  price       Float
  imageUrl    String?
  available   Boolean  @default(true)
  position    Int?

  categoryId  String
  category    MenuCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Reservation {
  id        String   @id @default(cuid())
  name      String
  phone     String
  guests    Int
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())
}